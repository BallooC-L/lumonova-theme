{%- comment -%}
  energy-label.liquid
  ---------------------------------------------------------------
  Renders the small EU energy-efficiency FLAG (A–G) + datasheet link.

  ── How the flag is chosen ──────────────────────────────────────
  The efficiency class is read from the product's spec_rows metaobjects
  (custom.spec_rows). We look for the row whose label matches the
  energy-class label (DE "Energieeffizienzklasse" / EN "Energy efficiency
  class"), take its value (e.g. "E"), and load the matching theme asset:

      assets/energieeffizienzklasse_<CLASS>.svg   e.g. _E.svg

  So the small flags live in the theme (versioned in the repo), and no
  per-product metafield is needed for them — only the class in spec_rows.

  ── Metafields still used (namespace: custom) ───────────────────
    • energy_label      → URL to the FULL product label image
                          (opens in a new tab when the flag is clicked)
    • energy_datasheet  → URL to the datasheet PDF (opens in new tab)
                          (translatable → EN storefront gets the EN PDF)
    • energy_title      → clickable datasheet word, e.g. "Produktdatenblatt"
                          (translatable)

  Usage:
    {% render 'energy-label', product: product %}                → PDP variant
    {% render 'energy-label', product: product, variant: 'card' %} → collection card
{%- endcomment -%}

{%- assign el_label = product.metafields.custom.energy_label -%}
{%- assign el_sheet = product.metafields.custom.energy_datasheet -%}
{%- assign el_title = product.metafields.custom.energy_title -%}

{%- comment -%} ── 1) Read the efficiency class from spec_rows ── {%- endcomment -%}
{%- assign el_class = '' -%}
{%- assign el_class_labels = 'Energieeffizienzklasse,Energy efficiency class,Energy Efficiency Class,Energieeffizienz' | split: ',' -%}
{%- assign spec_rows = product.metafields.custom.spec_rows.value -%}
{%- if spec_rows -%}
  {%- for row in spec_rows -%}
    {%- assign row_label = row.label -%}
    {%- if el_class_labels contains row_label -%}
      {%- assign el_class = row.value | strip -%}
      {%- break -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%} Normalise the class token: uppercase, keep only the letter(s) {%- endcomment -%}
{%- assign el_class = el_class | upcase | strip -%}

{%- comment -%} ── 2) Build the flag asset URL for that class ── {%- endcomment -%}
{%- assign el_flag_url = '' -%}
{%- assign valid_classes = 'A,B,C,D,E,F,G' | split: ',' -%}
{%- if valid_classes contains el_class -%}
  {%- assign el_flag_file = 'energieeffizienzklasse_' | append: el_class | append: '.svg' -%}
  {%- assign el_flag_url = el_flag_file | asset_url -%}
{%- endif -%}

{%- comment -%} ── 3) Resolve the FULL label URL (opened on flag click) ── {%- endcomment -%}
{%- assign el_label_url = '' -%}
{%- if el_label != blank -%}
  {%- if el_label.url -%}
    {%- assign el_label_url = el_label.url -%}
  {%- else -%}
    {%- assign el_label_url = el_label | image_url: width: 1000 -%}
    {%- if el_label_url == blank -%}{%- assign el_label_url = el_label -%}{%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} ── 4) Resolve the datasheet URL ── {%- endcomment -%}
{%- assign el_sheet_url = '' -%}
{%- if el_sheet != blank -%}
  {%- if el_sheet.url -%}
    {%- assign el_sheet_url = el_sheet.url -%}
  {%- else -%}
    {%- assign el_sheet_url = el_sheet -%}
  {%- endif -%}
{%- endif -%}

{%- comment -%} Fallback datasheet title if the metafield is empty {%- endcomment -%}
{%- if el_title == blank -%}
  {%- assign el_title = 'product.energy_datasheet_default' | t -%}
{%- endif -%}

{%- comment -%}
  The flag click target: prefer the full label; if no label URL is set yet,
  fall back to opening the datasheet so the flag still does something useful.
{%- endcomment -%}
{%- assign el_flag_target = el_label_url -%}
{%- if el_flag_target == blank -%}{%- assign el_flag_target = el_sheet_url -%}{%- endif -%}

{%- comment -%} Aria label incl. class, e.g. "Energieeffizienzklasse E – Label anzeigen" {%- endcomment -%}
{%- assign el_flag_aria = 'product.energy_label_aria' | t -%}
{%- if el_class != blank -%}
  {%- assign el_flag_aria = el_flag_aria | append: ' (' | append: el_class | append: ')' -%}
{%- endif -%}

{%- comment -%} Only render if we have a flag OR a datasheet to show ── {%- endcomment -%}
{%- if el_flag_url != blank or el_sheet_url != blank -%}
  {%- if variant == 'card' -%}
    {%- comment -%}
      ── COLLECTION CARD VARIANT ───────────────────────
      The whole product card is a single <a>, so we must NOT nest real
      <a> elements. We use role="link" spans that open a new tab via JS
      and stop the click from bubbling up to the card link.
    {%- endcomment -%}
    <div class="energy-label energy-label--card">
      {%- if el_flag_url != blank -%}
        <span
          class="energy-label__flag{% unless el_flag_target != blank %} energy-label__flag--static{% endunless %}"
          {% if el_flag_target != blank %}role="link" tabindex="0" data-energy-open="{{ el_flag_target }}" aria-label="{{ el_flag_aria }}"{% else %}aria-label="{{ el_flag_aria }}"{% endif %}
        >
          <img src="{{ el_flag_url }}" alt="{{ el_flag_aria }}" loading="lazy">
        </span>
      {%- endif -%}
      {%- if el_sheet_url != blank -%}
        <span
          class="energy-label__sheet"
          role="link"
          tabindex="0"
          data-energy-open="{{ el_sheet_url }}"
        >
          <span class="material-symbols-outlined" aria-hidden="true">description</span>
          <span class="energy-label__sheet-text">{{ el_title }}</span>
        </span>
      {%- endif -%}
    </div>
  {%- else -%}
    {%- comment -%} ── PDP VARIANT ─────────────────────────────────── {%- endcomment -%}
    <div class="energy-label energy-label--pdp">
      {%- if el_flag_url != blank -%}
        {%- if el_flag_target != blank -%}
          <a
            href="{{ el_flag_target }}"
            class="energy-label__flag"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="{{ el_flag_aria }}"
          >
            <img src="{{ el_flag_url }}" alt="{{ el_flag_aria }}" loading="lazy">
          </a>
        {%- else -%}
          <span class="energy-label__flag energy-label__flag--static" aria-label="{{ el_flag_aria }}">
            <img src="{{ el_flag_url }}" alt="{{ el_flag_aria }}" loading="lazy">
          </span>
        {%- endif -%}
      {%- endif -%}
      {%- if el_sheet_url != blank -%}
        <a
          href="{{ el_sheet_url }}"
          class="energy-label__sheet"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="material-symbols-outlined" aria-hidden="true">description</span>
          <span class="energy-label__sheet-text">{{ el_title }}</span>
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}

  {%- comment -%}
    One-time delegated handler for the card variant's role="link" spans.
    Opens the target in a new tab and prevents the click from triggering
    the surrounding product-card <a>. Guarded so it binds only once even
    when many cards render on one page.
  {%- endcomment -%}
  <script>
  (function () {
    if (window.__energyLabelBound) return;
    window.__energyLabelBound = true;

    function openTarget(el) {
      var url = el.getAttribute('data-energy-open');
      if (url) window.open(url, '_blank', 'noopener');
    }

    document.addEventListener('click', function (e) {
      var el = e.target.closest('[data-energy-open]');
      if (!el) return;
      e.preventDefault();
      e.stopPropagation();
      openTarget(el);
    });

    document.addEventListener('keydown', function (e) {
      if (e.key !== 'Enter' && e.key !== ' ') return;
      var el = e.target.closest('[data-energy-open]');
      if (!el) return;
      e.preventDefault();
      e.stopPropagation();
      openTarget(el);
    });
  })();
  </script>
{%- endif -%}

{%- assign locale_prefix = "" -%}
{%- unless localization.language.iso_code == "de" -%}
  {%- assign locale_prefix = "/" | append: localization.language.iso_code -%}
{%- endunless -%}

{%- assign cd_empty          = 'cart_drawer.empty'             | t -%}
{%- assign cd_empty_body     = 'cart_drawer.empty_body'        | t -%}
{%- assign cd_empty_cta      = 'cart_drawer.empty_cta'         | t -%}
{%- assign cd_empty_subtitle = 'cart_drawer.empty_subtitle'    | t -%}
{%- assign cd_item_singular  = 'cart_drawer.item_singular'     | t -%}
{%- assign cd_item_plural    = 'cart_drawer.item_plural'       | t -%}
{%- assign cd_qty_decrease   = 'cart_drawer.qty_decrease_aria' | t -%}
{%- assign cd_qty_increase   = 'cart_drawer.qty_increase_aria' | t -%}
{%- assign cd_remove_aria    = 'cart_drawer.remove_aria'       | t -%}
{%- assign cd_error_loading  = 'cart_drawer.error_loading'     | t -%}
{%- assign cd_toast_added    = 'cart_drawer.toast_added'       | t -%}

{%- comment -%}
  i18n-Strings als Data-Attribute auf einem versteckten Element.
  So kommt kein Liquid in den <script>-Block — JS liest die Werte
  aus dem DOM. Das ist die zuverlässigste Methode in Shopify-Snippets.
{%- endcomment -%}
<div id="cart-drawer-i18n" hidden
  data-empty="{{ cd_empty | escape }}"
  data-empty-body="{{ cd_empty_body | escape }}"
  data-empty-cta="{{ cd_empty_cta | escape }}"
  data-empty-subtitle="{{ cd_empty_subtitle | escape }}"
  data-item-singular="{{ cd_item_singular | escape }}"
  data-item-plural="{{ cd_item_plural | escape }}"
  data-qty-decrease="{{ cd_qty_decrease | escape }}"
  data-qty-increase="{{ cd_qty_increase | escape }}"
  data-remove-aria="{{ cd_remove_aria | escape }}"
  data-error-loading="{{ cd_error_loading | escape }}"
  data-toast-added="{{ cd_toast_added | escape }}"
  data-locale-prefix="{{ locale_prefix | escape }}"
></div>

<style>
.cart-drawer-backdrop{position:fixed;inset:0;z-index:9000;background:rgba(10,9,8,.70);backdrop-filter:blur(2px);-webkit-backdrop-filter:blur(2px);opacity:0;pointer-events:none;transition:opacity .30s ease}
.cart-drawer-backdrop.is-open{opacity:1;pointer-events:auto}
.cart-drawer{position:fixed!important;top:0!important;right:0!important;bottom:0!important;left:auto!important;z-index:9001!important;width:100%;max-width:420px;background:#1a1814;border-left:1px solid rgba(255,255,255,.07);box-shadow:-24px 0 60px rgba(0,0,0,.55);display:flex;flex-direction:column;transform:translateX(100%);transition:transform .35s cubic-bezier(.4,0,.2,1);will-change:transform;margin:0;padding:0;float:none}
.cart-drawer.is-open{transform:translateX(0)!important}
.cart-drawer__header{display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;padding:1.75rem 1.5rem 1.25rem;border-bottom:1px solid rgba(255,255,255,.06);flex-shrink:0}
.cart-drawer__title{font-size:20px;font-weight:700;color:rgba(242,242,242,1);letter-spacing:-.01em;margin:0}
.cart-drawer__subtitle{font-size:12px;color:rgba(242,242,242,.35);margin-top:.2rem;margin-bottom:0;letter-spacing:.02em}
.cart-drawer__close{width:34px;height:34px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);border-radius:50%;color:rgba(242,242,242,.60);flex-shrink:0;transition:background .15s,color .15s;cursor:pointer}
.cart-drawer__close:hover{background:rgba(255,255,255,.10);color:rgba(242,242,242,.82)}
.cart-drawer__body{flex:1;overflow-y:auto;overscroll-behavior:contain;padding:1rem 1.5rem;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.08) transparent}
.cart-drawer__body::-webkit-scrollbar{width:4px}
.cart-drawer__body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px}
.cart-drawer__loading{display:flex;align-items:center;justify-content:center;padding:4rem 0}
.cart-drawer__loading-icon{font-size:40px;color:rgba(242,242,242,.08);animation:cdpulse 1.4s ease-in-out infinite}
@keyframes cdpulse{0%,100%{opacity:.3}50%{opacity:.7}}
.cart-drawer__empty{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 1.5rem;gap:1rem}
.cart-drawer__empty-icon{font-size:48px;color:rgba(242,242,242,.08)}
.cart-drawer__empty-title{font-size:16px;font-weight:700;color:rgba(242,242,242,.60);margin:0}
.cart-drawer__empty-body{font-size:13px;color:rgba(242,242,242,.45);line-height:1.5;margin:0}
.cart-drawer__empty-cta{display:inline-flex;align-items:center;gap:4px;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.10em;color:#e8a060;margin-top:.5rem;text-decoration:none}
.cart-line{display:grid;grid-template-columns:72px 1fr auto;gap:1rem;align-items:flex-start;padding:1.125rem 0;border-bottom:1px solid rgba(255,255,255,.05)}
.cart-line:last-child{border-bottom:none}
.cart-line__image{width:72px;height:72px;border-radius:.5rem;background:#0e0d0b;border:1px solid rgba(255,255,255,.07);object-fit:contain;flex-shrink:0;padding:4px;display:block}
.cart-line__image--placeholder{width:72px;height:72px;border-radius:.5rem;background:#0e0d0b;border:1px solid rgba(255,255,255,.07);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cart-line__info{display:flex;flex-direction:column;gap:.3rem;min-width:0}
.cart-line__name{font-size:14px;font-weight:600;color:rgba(242,242,242,.82);line-height:1.3;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin:0}
.cart-line__variant{font-size:11px;color:rgba(242,242,242,.35);text-transform:uppercase;letter-spacing:.05em;margin:0}
.cart-line__price{font-size:14px;font-weight:700;color:rgba(242,242,242,1);margin-top:.25rem;margin-bottom:0}
.cart-line__qty{display:flex;align-items:center;gap:.375rem;margin-top:.625rem}
.cart-line__qty-btn{width:26px;height:26px;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.09);border-radius:.375rem;color:rgba(242,242,242,.60);font-size:14px;line-height:1;transition:background .15s,color .15s;cursor:pointer;font-family:inherit}
.cart-line__qty-btn:hover{background:rgba(255,255,255,.10);color:rgba(242,242,242,.82)}
.cart-line__qty-num{font-size:13px;font-weight:600;color:rgba(242,242,242,.82);min-width:20px;text-align:center}
.cart-line__remove{display:flex;align-items:center;justify-content:center;width:30px;height:30px;background:none;border:none;color:rgba(242,242,242,.35);border-radius:50%;transition:background .15s,color .15s;flex-shrink:0;margin-top:4px;cursor:pointer}
.cart-line__remove:hover{background:rgba(232,80,80,.10);color:#e85050}
.cart-drawer__footer{flex-shrink:0;padding:1.25rem 1.5rem 1.5rem;border-top:1px solid rgba(255,255,255,.06);display:flex;flex-direction:column;gap:1rem;background:#1a1814}
.cart-drawer__subtotal{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:.5rem}
.cart-drawer__subtotal-label{font-size:13px;font-weight:500;color:rgba(242,242,242,.60);text-transform:uppercase;letter-spacing:.08em;margin:0}
.cart-drawer__subtotal-value{font-size:18px;font-weight:700;color:rgba(242,242,242,1)}
.cart-drawer__checkout-btn{display:flex!important;width:100%;justify-content:center;align-items:center;gap:.5rem;font-size:13px;padding:1rem;background:#e8a060;color:#fff;font-weight:700;letter-spacing:.10em;text-transform:uppercase;border:1px solid transparent;border-radius:.5rem;transition:box-shadow .2s,background .2s;text-decoration:none;box-sizing:border-box;cursor:pointer;font-family:inherit}
.cart-drawer__checkout-btn:hover{box-shadow:0 0 30px rgba(232,160,96,.4)}
.cart-drawer__trust{display:flex;align-items:center;justify-content:center;gap:.5rem}
.cart-drawer__trust-icon{font-size:16px;color:rgba(232,160,96,.55)}
.cart-drawer__trust-text{font-size:11px;color:rgba(242,242,242,.35);letter-spacing:.03em}
.cart-toast{position:fixed;top:1.5rem;right:1.5rem;z-index:9010;display:flex;align-items:center;gap:.625rem;padding:.75rem 1.125rem;background:#201e1b;border:1px solid rgba(76,175,138,.30);border-radius:.625rem;box-shadow:0 8px 32px rgba(0,0,0,.45);transform:translateX(calc(100% + 2rem));opacity:0;transition:transform .30s cubic-bezier(.4,0,.2,1),opacity .30s ease;pointer-events:none}
.cart-toast.is-visible{transform:translateX(0);opacity:1}
.cart-toast__icon{font-size:18px;color:#4caf8a}
.cart-toast__text{font-size:13px;font-weight:600;color:rgba(242,242,242,.82);white-space:nowrap}
body.cart-drawer-open{overflow:hidden!important}
</style>

<div id="cart-drawer-backdrop" class="cart-drawer-backdrop" aria-hidden="true" onclick="closeCartDrawer()"></div>

<div id="cart-toast" class="cart-toast" role="status" aria-live="polite" aria-atomic="true">
  <span class="material-symbols-outlined cart-toast__icon" aria-hidden="true">check_circle</span>
  <span class="cart-toast__text">{{ cd_toast_added }}</span>
</div>

<div id="cart-drawer" class="cart-drawer" role="dialog" aria-modal="true" aria-label="{{ 'cart_drawer.aria_label' | t }}" aria-hidden="true">
  <div class="cart-drawer__header">
    <div>
      <h2 class="cart-drawer__title">{{ 'cart_drawer.title' | t }}</h2>
      <p class="cart-drawer__subtitle" id="cart-drawer-subtitle">{{ 'cart_drawer.loading' | t }}</p>
    </div>
    <button type="button" class="cart-drawer__close" onclick="closeCartDrawer()" aria-label="{{ 'cart_drawer.close_aria' | t }}">
      <span class="material-symbols-outlined" style="font-size:22px;" aria-hidden="true">close</span>
    </button>
  </div>
  <div class="cart-drawer__body" id="cart-drawer-body">
    <div class="cart-drawer__loading">
      <span class="material-symbols-outlined cart-drawer__loading-icon" aria-hidden="true">shopping_bag</span>
    </div>
  </div>
  <div class="cart-drawer__footer" id="cart-drawer-footer" style="display:none;">
    <div class="cart-drawer__subtotal">
      <span class="cart-drawer__subtotal-label">{{ 'cart_drawer.subtotal' | t }}</span>
      <span class="cart-drawer__subtotal-value" id="cart-drawer-total">–</span>
    </div>
    <a href="/checkout" class="cart-drawer__checkout-btn">
      <span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">lock</span>
      {{ 'cart_drawer.checkout' | t }}
    </a>
    <div class="cart-drawer__trust">
      <span class="material-symbols-outlined cart-drawer__trust-icon" aria-hidden="true">verified_user</span>
      <span class="cart-drawer__trust-text">{{ 'cart_drawer.trust_text' | t }}</span>
    </div>
  </div>
</div>

<script>
(function(){
  // Strings aus Data-Attributen lesen — kein Liquid im JS-Block
  var _el = document.getElementById('cart-drawer-i18n');
  var _i18n = {
    empty:         _el.dataset.empty,
    emptyBody:     _el.dataset.emptyBody,
    emptyCta:      _el.dataset.emptyCta,
    emptySubtitle: _el.dataset.emptySubtitle,
    itemSingular:  _el.dataset.itemSingular,
    itemPlural:    _el.dataset.itemPlural,
    qtyDecrease:   _el.dataset.qtyDecrease,
    qtyIncrease:   _el.dataset.qtyIncrease,
    removeAria:    _el.dataset.removeAria,
    errorLoading:  _el.dataset.errorLoading,
    toastAdded:    _el.dataset.toastAdded,
    localePrefix:  _el.dataset.localePrefix
  };

  function fmt(c){
    var locale = document.documentElement.lang || 'de';
    return (c/100).toLocaleString(locale,{style:'currency',currency:'EUR'});
  }
  function el(id){return document.getElementById(id);}
  function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}
  var tt = null;

  function showToast(msg){
    var t=el('cart-toast');if(!t)return;
    var tx=t.querySelector('.cart-toast__text');if(tx)tx.textContent=msg||_i18n.toastAdded;
    t.classList.add('is-visible');clearTimeout(tt);
    tt=setTimeout(function(){t.classList.remove('is-visible');},2800);
  }

  window.openCartDrawer=function(){
    var d=el('cart-drawer'),b=el('cart-drawer-backdrop');if(!d)return;
    d.classList.add('is-open');d.setAttribute('aria-hidden','false');
    if(b)b.classList.add('is-open');
    document.body.classList.add('cart-drawer-open');
    var c=d.querySelector('.cart-drawer__close');if(c)setTimeout(function(){c.focus();},50);
    renderCart();
  };

  window.closeCartDrawer=function(){
    var d=el('cart-drawer'),b=el('cart-drawer-backdrop');if(!d)return;
    d.classList.remove('is-open');d.setAttribute('aria-hidden','true');
    if(b)b.classList.remove('is-open');
    document.body.classList.remove('cart-drawer-open');
  };

  document.addEventListener('keydown',function(e){
    if(e.key==='Escape'){var d=el('cart-drawer');if(d&&d.classList.contains('is-open'))closeCartDrawer();}
  });

  function renderCart(){
    var body=el('cart-drawer-body'),footer=el('cart-drawer-footer'),sub=el('cart-drawer-subtitle');
    if(!body)return;
    body.innerHTML='<div class="cart-drawer__loading"><span class="material-symbols-outlined cart-drawer__loading-icon" aria-hidden="true">shopping_bag</span></div>';
    if(footer)footer.style.display='none';
    fetch('/cart.js').then(function(r){return r.json();}).then(function(cart){
      updateBadges(cart.item_count);
      if(sub){
        if(cart.item_count===0) sub.textContent=_i18n.emptySubtitle;
        else if(cart.item_count===1) sub.textContent='1 '+_i18n.itemSingular;
        else sub.textContent=cart.item_count+' '+_i18n.itemPlural;
      }
      if(cart.item_count===0){
        body.innerHTML=
          '<div class="cart-drawer__empty">'
          +'<span class="material-symbols-outlined cart-drawer__empty-icon" aria-hidden="true">shopping_bag</span>'
          +'<p class="cart-drawer__empty-title">'+_i18n.empty+'</p>'
          +'<p class="cart-drawer__empty-body">'+_i18n.emptyBody+'</p>'
          +'<a href="'+_i18n.localePrefix+'/collections/all" class="cart-drawer__empty-cta" onclick="closeCartDrawer()">'
          +_i18n.emptyCta
          +' <span class="material-symbols-outlined" style="font-size:15px;vertical-align:middle;" aria-hidden="true">arrow_forward</span>'
          +'</a></div>';
        if(footer)footer.style.display='none';
        return;
      }
      var html='';
      cart.items.forEach(function(item){
        var img=item.image
          ?'<img src="'+item.image+'" alt="'+esc(item.product_title)+'" class="cart-line__image" loading="lazy">'
          :'<div class="cart-line__image--placeholder"><span class="material-symbols-outlined" style="font-size:24px;color:rgba(242,242,242,.35);" aria-hidden="true">image_not_supported</span></div>';
        var vari=(item.variant_title&&item.variant_title!=='Default Title')
          ?'<p class="cart-line__variant">'+esc(item.variant_title)+'</p>':'';
        html+=
          '<div class="cart-line">'+img
          +'<div class="cart-line__info">'
          +'<p class="cart-line__name">'+esc(item.product_title)+'</p>'+vari
          +'<p class="cart-line__price">'+fmt(item.line_price)+'</p>'
          +'<div class="cart-line__qty">'
          +'<button type="button" class="cart-line__qty-btn" onclick="cartUpdateQty(\''+item.key+'\','+(item.quantity-1)+')" aria-label="'+_i18n.qtyDecrease+'">−</button>'
          +'<span class="cart-line__qty-num">'+item.quantity+'</span>'
          +'<button type="button" class="cart-line__qty-btn" onclick="cartUpdateQty(\''+item.key+'\','+(item.quantity+1)+')" aria-label="'+_i18n.qtyIncrease+'">+</button>'
          +'</div></div>'
          +'<button type="button" class="cart-line__remove" onclick="cartRemoveItem(\''+item.key+'\')" aria-label="'+esc(item.product_title)+' '+_i18n.removeAria+'">'
          +'<span class="material-symbols-outlined" style="font-size:18px;" aria-hidden="true">delete_outline</span>'
          +'</button>'
          +'</div>';
      });
      body.innerHTML=html;
      if(footer){
        var tot=el('cart-drawer-total');
        if(tot)tot.textContent=fmt(cart.total_price);
        footer.style.display='flex';
      }
    }).catch(function(){
      body.innerHTML='<p style="color:rgba(242,242,242,.45);font-size:14px;padding:2rem 0;text-align:center;">'+_i18n.errorLoading+'</p>';
    });
  }

  window.cartUpdateQty=function(key,qty){if(qty<0)return;doPost('/cart/change.js',{id:key,quantity:qty});};
  window.cartRemoveItem=function(key){doPost('/cart/change.js',{id:key,quantity:0});};

  function doPost(url,data){
    var b=el('cart-drawer-body');if(b)b.style.opacity='.5';
    fetch(url,{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify(data)})
      .then(function(r){return r.json();})
      .then(function(){if(b)b.style.opacity='1';renderCart();})
      .catch(function(){if(b)b.style.opacity='1';});
  }

  window.addToCartAndOpen=function(variantId,qty){
    fetch('/cart/add.js',{method:'POST',headers:{'Content-Type':'application/json','Accept':'application/json'},body:JSON.stringify({id:variantId,quantity:qty||1})})
      .then(function(r){return r.json();})
      .then(function(item){
        showToast('\u201e'+(item.product_title||'Produkt')+'\u201c '+_i18n.toastAdded);
        openCartDrawer();
      })
      .catch(function(){openCartDrawer();});
  };

  function updateBadges(count){
    document.querySelectorAll('[data-cart-count]').forEach(function(b){
      b.textContent=count;b.style.display=count>0?'flex':'none';
    });
  }

  document.addEventListener('DOMContentLoaded',function(){
    fetch('/cart.js').then(function(r){return r.json();}).then(function(c){updateBadges(c.item_count);}).catch(function(){});
  });
})();
</script>

<div class="announcement-bar">
  <div class="container">
    <p class="announcement-bar__text">{{ section.settings.text }}</p>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Text",
      "default": "Matter over Wi-Fi · 3 Jahre EU-Garantie"
    }
  ]
}
{% endschema %}

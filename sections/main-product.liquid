{%- assign locale_prefix = "" -%}
{%- unless localization.language.iso_code == "de" -%}
  {%- assign locale_prefix = "/" | append: localization.language.iso_code -%}
{%- endunless -%}
{%- comment -%}
  main-product.liquid
  Produktdetailseite
{%- endcomment -%}

{%- assign product = product -%}
{%- assign tier = product.metafields.custom.tier | default: '' -%}
{%- assign short_desc = product.metafields.custom.short_description | default: product.description | strip_html | truncate: 120 -%}
{%- assign usps = product.metafields.custom.usps.value -%}
{%- assign feature_blocks = product.metafields.custom.feature_blocks.value -%}
{%- assign has_features = false -%}
{%- if feature_blocks and feature_blocks.size > 0 -%}{%- assign has_features = true -%}{%- endif -%}
{%- assign has_compatibility = product.metafields.custom.compatibility -%}
{%- assign intro_hero_image = product.metafields.custom.intro_hero_image -%}
{%- assign intro_hero_eyebrow = product.metafields.custom.intro_hero_eyebrow -%}
{%- assign intro_hero_headline = product.metafields.custom.intro_hero_headline -%}
{%- assign warranty = product.metafields.custom.warranty | default: '3 Jahre EU-Garantie' -%}
{%- assign cta_external_url = product.metafields.custom.cta_external_url -%}
{%- assign cta_external_label = product.metafields.custom.cta_external_label -%}

{%- assign price_is_request = false -%}
{%- if product.price == 0 -%}{%- assign price_is_request = true -%}{%- endif -%}

{%- comment -%}
  ════════════════════════════════════════════════
  SECTION 1 — HERO (Gallery + Info)
  ════════════════════════════════════════════════
{%- endcomment -%}
<section class="bg-base" aria-label="{{ 'product.hero_aria' | t }}">
  <div class="container product-hero">

    {%- comment -%} LEFT: Gallery {%- endcomment -%}
    <div class="product-gallery">
      <div class="product-gallery__main" id="gallery-main">
        <div class="glow-stage" aria-hidden="true">
          <div style="position:absolute; inset:0; background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.015) 0px, transparent 1px, transparent 32px), repeating-linear-gradient(90deg, rgba(255,255,255,0.015) 0px, transparent 1px, transparent 32px); z-index:1;"></div>
          <div class="glow-stage__ring" style="width:400px; height:400px; background:rgba(232,160,96,0.08); filter:blur(80px);"></div>
          <div class="glow-stage__ring" style="width:220px; height:220px; background:rgba(232,160,96,0.22); filter:blur(35px);"></div>
          <div class="glow-stage__ring" style="width:200px; height:200px; border:1px solid rgba(232,160,96,0.35);"></div>
          <div class="glow-stage__ring" style="width:280px; height:280px; border:1px solid rgba(232,160,96,0.15);"></div>
          <div class="glow-stage__ring" style="width:360px; height:360px; border:1px solid rgba(232,160,96,0.06);"></div>
          <div style="position:absolute; width:180px; height:40px; border-radius:50%; background:rgba(232,160,96,0.18); filter:blur(20px); bottom:40px; left:50%; transform:translateX(-50%);"></div>
        </div>

        {%- if product.featured_image -%}
          <img
            id="gallery-active-img"
            src="{{ product.featured_image | img_url: '800x' }}"
            alt="{{ product.featured_image.alt | escape | default: product.title }}"
            class="product-gallery__img"
            style="position:relative; z-index:10;"
            loading="eager"
          >
        {%- else -%}
          <p class="product-gallery__placeholder" style="position:relative; z-index:10;">{{ 'product.image_coming' | t }}</p>
        {%- endif -%}

        <p id="gallery-placeholder" class="product-gallery__placeholder" style="display:none; position:relative; z-index:10;"></p>

        <button type="button" class="product-gallery__nav product-gallery__nav--prev" id="gallery-prev" aria-label="{{ 'product.gallery_prev' | t }}">
          <span class="material-symbols-outlined" style="font-size:21px;" aria-hidden="true">chevron_left</span>
        </button>
        <button type="button" class="product-gallery__nav product-gallery__nav--next" id="gallery-next" aria-label="{{ 'product.gallery_next' | t }}">
          <span class="material-symbols-outlined" style="font-size:21px;" aria-hidden="true">chevron_right</span>
        </button>
      </div>

      <div class="product-gallery__thumbs" id="gallery-thumbs" role="list">
        {%- assign gallery_images = product.images -%}
        {%- for image in gallery_images limit: 8 -%}
          <button
            type="button"
            class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}"
            data-index="{{ forloop.index0 }}"
            data-src="{{ image | img_url: '800x' }}"
            aria-label="{{ 'product.gallery_thumb_aria' | t: index: forloop.index }}"
            {% if forloop.first %}aria-current="true"{% endif %}
            role="listitem"
          >
            <img src="{{ image | img_url: '150x150' }}" alt="{{ image.alt | escape | default: product.title }}" loading="lazy">
          </button>
        {%- endfor -%}
        {%- comment -%}{%- for i in (gallery_images.size..7) -%}
          <button type="button" class="product-gallery__thumb" data-index="{{ i }}" data-src="" aria-label="{{ 'product.gallery_thumb_placeholder' | t: index: i | plus: 1 }}" role="listitem">
            {{ 'product.gallery_image_label' | t }} {{ i | plus: 1 }}
          </button>
        {%- endfor -%}{%- endcomment -%}
      </div>
    </div>

    {%- comment -%} RIGHT: Product info {%- endcomment -%}
    <div class="product-info">
      <nav class="product-breadcrumb" aria-label="{{ 'product.breadcrumb_aria' | t }}">
        <a href="{{ locale_prefix }}/collections/all" style="color:inherit;">{{ 'product.breadcrumb_products' | t }}</a>
        &rarr;
        <a href="{{ locale_prefix }}/collections/{{ product.type | handleize }}" style="color:inherit;">{{ product.type }}</a>
        &rarr; {{ product.metafields.custom.sku | default: product.variants.first.sku }}
      </nav>

      {%- if tier != blank -%}
        <span class="tier-pill">{{ tier }}</span>
      {%- endif -%}

      <h1 class="product-info__name">{{ product.title }}</h1>
      <p class="product-info__sku">{{ product.metafields.custom.sku | default: product.variants.first.sku }}</p>

      {% render 'energy-label', product: product %}

      <p class="product-info__short-desc">{{ short_desc }}</p>

      {%- if usps -%}
        <ul class="product-info__usps" role="list">
          {%- for usp in usps -%}
            <li class="product-info__usp" role="listitem">{{ usp }}</li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      <p class="product-info__price{% if price_is_request %} product-info__price--request{% endif %}">
        {%- if price_is_request -%}
          {{ 'product.price_on_request' | t }}
        {%- else -%}
          {{ product.price | money }}
        {%- endif -%}
      </p>

      {%- unless price_is_request -%}
        {%- assign delivery_time = product.metafields.custom.delivery_time -%}
        {%- unless delivery_time -%}
          {%- if localization.market.handle == 'eu' -%}
            {%- assign delivery_time = 'product.delivery_default_eu' | t -%}
          {%- else -%}
            {%- assign delivery_time = 'product.delivery_default_de' | t -%}
          {%- endif -%}
        {%- endunless -%}
        {%- unless product.available -%}
          {%- assign delivery_time = 'product.unavailable' | t -%}
        {%- endunless -%}
        <div class="product-info__legal">
          <span class="product-info__legal-item">
            <span class="material-symbols-outlined" aria-hidden="true" style="font-size:13px; vertical-align:-2px;">info</span>
            {{ 'product.incl_vat' | t }}
          </span>
          <span class="product-info__legal-sep" aria-hidden="true">·</span>
          <span class="product-info__legal-item">
            <span class="material-symbols-outlined" aria-hidden="true" style="font-size:13px; vertical-align:-2px;">local_shipping</span>
            <a href="{{ locale_prefix }}/policies/shipping-policy" class="product-info__legal-link">{{ 'product.shipping_costs' | t }}</a> {{ 'product.shipping_calculated' | t }}
          </span>
          <span class="product-info__legal-sep" aria-hidden="true">·</span>
          <span class="product-info__legal-item">
            <span class="material-symbols-outlined" aria-hidden="true" style="font-size:13px; vertical-align:-2px;">schedule</span>
            {{ 'product.delivery_time' | t }}: {{ delivery_time }}
          </span>
        </div>
      {%- endunless -%}

      <div class="product-info__ctas">
        {%- assign cta_buy_default = 'product.cta_buy_default' | t -%}
        {%- assign cta_amazon_default = 'product.cta_amazon_default' | t -%}
        {%- if cta_external_url != blank -%}
          <a href="{{ cta_external_url }}" target="_blank" rel="noopener noreferrer" class="btn-amber"
             aria-label="{{ product.title }} – {{ cta_external_label | default: cta_buy_default }}">
            {{ cta_external_label | default: cta_amazon_default }}
          </a>
        {%- elsif price_is_request -%}
          <a href="mailto:support@lumonova.com?subject=Anfrage%20{{ product.title | url_encode }}" class="btn-amber">
            {{ 'product.cta_inquiry' | t }}
          </a>
        {%- else -%}
          <button
            type="button"
            class="btn-amber"
            onclick="addToCartAndOpen({{ product.variants.first.id }}, 1)"
          >
            {{ 'products.product.add_to_cart' | t }}
          </button>
        {%- endif -%}
        <button type="button" class="btn-ghost" onclick="scrollToSpecs()">{{ 'product.cta_specs' | t }}</button>
      </div>
    </div>
  </div>
</section>

{%- comment -%}
  ════════════════════════════════════════════════
  SECTION 2 — INTRO HERO BANNER (optional)
  ════════════════════════════════════════════════
{%- endcomment -%}
{%- if intro_hero_image != blank -%}
  <section class="intro-hero" aria-hidden="true">
    <img src="{{ intro_hero_image | img_url: '2000x' }}" alt="" class="intro-hero__img" loading="lazy">
    <div class="intro-hero__gradient-top"></div>
    <div class="intro-hero__gradient-bottom"></div>
    <div class="intro-hero__content">
      {%- if intro_hero_eyebrow != blank -%}
        <p class="intro-hero__eyebrow">{{ intro_hero_eyebrow }}</p>
      {%- endif -%}
      {%- if intro_hero_headline != blank -%}
        <h2 class="intro-hero__headline">{{ intro_hero_headline }}</h2>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

{%- comment -%}
  ════════════════════════════════════════════════
  SECTION 3 — STICKY SUB NAV
  ════════════════════════════════════════════════
{%- endcomment -%}
<nav class="product-subnav" aria-label="{{ 'product.subnav_aria' | t }}">
  <div class="container product-subnav__inner">
    {%- if has_features -%}
      <a href="#features" class="product-subnav__tab is-active" data-tab="features">{{ 'product.tab_description' | t }}</a>
    {%- endif -%}
    <a href="#specs" class="product-subnav__tab{% unless has_features %} is-active{% endunless %}" data-tab="specs">{{ 'product.tab_specs' | t }}</a>
  </div>
</nav>

{%- comment -%}
  ════════════════════════════════════════════════
  SECTION 4 — FEATURES (optional)
  ════════════════════════════════════════════════
{%- endcomment -%}
{%- if has_features -%}
  {%- assign features = feature_blocks -%}
  {%- if features.size > 0 -%}
    <section
      id="features"
      class="section bg-base"
      style="scroll-margin-top: 120px;"
      aria-labelledby="features-heading"
    >
      <div class="container">
        <div class="section-heading">
          <p class="section-eyebrow">{{ 'product.features_eyebrow' | t }}</p>
          <h2 class="section-title" id="features-heading">{{ 'product.features_title' | t }}</h2>
          {%- if product.type == 'Smart Bulbs' -%}
            <p class="section-subtitle">{{ 'product.features_subtitle_smart_bulbs' | t }}</p>
          {%- endif -%}
        </div>
        {%- for feature in features -%}
          {%- comment -%} image_on_left comes from a metaobject boolean field {%- endcomment -%}
          {%- assign img_left = false -%}
          {%- if feature.image_on_left == true or feature.image_on_left == 'true' -%}{%- assign img_left = true -%}{%- endif -%}

          {%- comment -%} image_src is a File(Image) field → resolve directly via image_url {%- endcomment -%}
          {%- assign feat_img_url = '' -%}
          {%- if feature.image_src != blank -%}
            {%- assign feat_img_url = feature.image_src | image_url: width: 1600 -%}
            {%- if feat_img_url == blank -%}
              {%- comment -%} fallbacks: generic file url, or plain URL string {%- endcomment -%}
              {%- if feature.image_src.url -%}
                {%- assign feat_img_url = feature.image_src.url -%}
              {%- else -%}
                {%- assign feat_img_url = feature.image_src -%}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}

          <div class="feature-block{% unless img_left %} feature-block--text-first{% endunless %}">
            {%- if img_left -%}
              <div class="feature-block__image">
                {%- if feat_img_url != blank -%}
                  <img src="{{ feat_img_url }}" alt="{{ feature.image_alt | escape }}" loading="lazy">
                {%- else -%}
                  <div class="feature-block__image feature-block__image--placeholder">FEATURE-BILD / 1600 × 1200</div>
                {%- endif -%}
              </div>
              <div class="feature-block__text">
                <p class="feature-block__eyebrow">{{ feature.eyebrow | upcase }}</p>
                <h3 class="feature-block__title">{{ feature.title }}</h3>
                <p class="feature-block__body">{{ feature.text }}</p>
              </div>
            {%- else -%}
              <div class="feature-block__text">
                <p class="feature-block__eyebrow">{{ feature.eyebrow | upcase }}</p>
                <h3 class="feature-block__title">{{ feature.title }}</h3>
                <p class="feature-block__body">{{ feature.text }}</p>
              </div>
              <div class="feature-block__image">
                {%- if feat_img_url != blank -%}
                  <img src="{{ feat_img_url }}" alt="{{ feature.image_alt | escape }}" loading="lazy">
                {%- else -%}
                  <div class="feature-block__image feature-block__image--placeholder">FEATURE-BILD / 1600 × 1200</div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}
{%- endif -%}

{%- comment -%}
  ════════════════════════════════════════════════
  SECTION 5 — SPECS TABLE
  ════════════════════════════════════════════════
{%- endcomment -%}
<section
  id="specs"
  class="section bg-mid"
  style="scroll-margin-top: 120px;"
  aria-labelledby="specs-heading"
>
  <div class="container">
    <div style="display:grid; grid-template-columns:1fr; gap:3rem; align-items:start;">
      <div style="position:sticky; top:168px; grid-column:1;">
        <p class="section-eyebrow">{{ 'product.specs_eyebrow' | t }}</p>
        <h2 class="section-title" id="specs-heading">{{ 'product.specs_title' | t }}</h2>
        <div style="width:2rem; height:2px; background:var(--color-amber); margin-top:1rem;"></div>
      </div>
    </div>

    {%- assign specs = product.metafields.custom.spec_rows.value -%}
    <div role="table" aria-label="{{ 'product.specs_eyebrow' | t }}" style="margin-top:2rem;">
      {%- if specs and specs.size > 0 -%}
        {%- for spec in specs -%}
          {%- assign is_accent = false -%}
          {%- if spec.accent == true or spec.accent == 'true' -%}{%- assign is_accent = true -%}{%- endif -%}
          <div class="spec-row" role="row">
            <div class="spec-row__label" role="rowheader">{{ spec.label }}</div>
            <div class="spec-row__value{% if is_accent %} spec-row__value--accent{% endif %}" role="cell">{{ spec.value }}</div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <p style="color:var(--fg-mid); font-size:14px;">{{ 'product.specs_coming' | t }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{%- comment -%}
  ════════════════════════════════════════════════
  SECTION 6 — COMPATIBILITY (Smart products only)
  ════════════════════════════════════════════════
{%- endcomment -%}
{%- if has_compatibility -%}
  <section class="section bg-base" aria-labelledby="compat-heading">
    <div class="container">
      <div class="section-heading">
        <p class="section-eyebrow">{{ 'product.compat_eyebrow' | t }}</p>
        <h2 class="section-title" id="compat-heading">{{ 'product.compat_title' | t }}</h2>
      </div>
      {% render 'compatibility-grid' %}
    </div>
  </section>
{%- endif -%}

{%- comment -%}
  ════════════════════════════════════════════════
  SECTION 7 — TRUST ROW
  ════════════════════════════════════════════════
{%- endcomment -%}
{% render 'trust-row' %}

{%- comment -%} Gallery JS {%- endcomment -%}
<script>
(function() {
  var thumbs = document.querySelectorAll('.product-gallery__thumb');
  var mainImg = document.getElementById('gallery-active-img');
  var placeholder = document.getElementById('gallery-placeholder');
  var activeIndex = 0;
  var total = thumbs.length;

  function setActive(index) {
    activeIndex = index;
    thumbs.forEach(function(t, i) {
      t.classList.toggle('is-active', i === index);
      t.setAttribute('aria-current', i === index ? 'true' : 'false');
    });
    var src = thumbs[index] ? thumbs[index].dataset.src : '';
    if (src && mainImg) {
      mainImg.src = src;
      mainImg.style.display = 'block';
      if (placeholder) placeholder.style.display = 'none';
    } else if (mainImg) {
      mainImg.style.display = 'none';
      if (placeholder) {
        placeholder.style.display = 'block';
        placeholder.textContent = 'BILD ' + (index + 1);
      }
    }
  }

  thumbs.forEach(function(thumb, i) {
    thumb.addEventListener('click', function() { setActive(i); });
  });

  var prev = document.getElementById('gallery-prev');
  var next = document.getElementById('gallery-next');
  if (prev) prev.addEventListener('click', function() { setActive((activeIndex - 1 + total) % total); });
  if (next) next.addEventListener('click', function() { setActive((activeIndex + 1) % total); });
})();

function scrollToSpecs() {
  var el = document.getElementById('specs');
  if (!el) return;
  var top = el.getBoundingClientRect().top + window.scrollY - 120;
  window.scrollTo({ top: top, behavior: 'smooth' });
}

(function() {
  var tabs = document.querySelectorAll('.product-subnav__tab');
  var sections = [];
  tabs.forEach(function(tab) {
    var id = tab.dataset.tab;
    if (id) {
      var el = document.getElementById(id);
      if (el) sections.push({ id: id, el: el });
    }
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      var id = tab.dataset.tab;
      var target = document.getElementById(id);
      if (target) {
        var top = target.getBoundingClientRect().top + window.scrollY - 120;
        window.scrollTo({ top: top, behavior: 'smooth' });
      }
    });
  });

  if (sections.length) {
    var obs = new IntersectionObserver(function(entries) {
      var visible = entries.filter(function(e) { return e.isIntersecting; });
      if (!visible.length) return;
      visible.sort(function(a, b) {
        return Math.abs(a.boundingClientRect.top) - Math.abs(b.boundingClientRect.top);
      });
      var activeId = visible[0].target.id;
      tabs.forEach(function(tab) {
        tab.classList.toggle('is-active', tab.dataset.tab === activeId);
      });
    }, { rootMargin: '-130px 0px -50% 0px', threshold: 0 });
    sections.forEach(function(s) { obs.observe(s.el); });
  }
})();
</script>

{% schema %}
{
  "name": "Produkt",
  "settings": []
}
{% endschema %}

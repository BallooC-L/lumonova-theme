<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ shop.name }} — Coming Soon</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    {{ content_for_header }}
    {{ 'base.css' | asset_url | stylesheet_tag }}
  </head>
  <body class="bg-base" style="min-height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem;">
    <img src="{{ 'LUMOnova_Logo_White.webp' | asset_url }}" alt="LUMOnova" style="height:48px; margin-bottom:2rem;">
    <h1 style="font-size:1.5rem; font-weight:700; color:rgba(242,242,242,0.85); margin-bottom:0.5rem;">{{ shop.name }}</h1>
    <p style="color:rgba(242,242,242,0.45); margin-bottom:2rem;">{{ 'coming_soon' | t }}</p>
    {{ content_for_layout }}
  </body>
</html>
